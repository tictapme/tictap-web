    "preview": "npm run astro:build && node bin/sync-astro-output.js && node bin/optimize-seo.js && node bin/preview.js src",
    "preview:src": "node bin/preview.js src",
    "astro:build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
