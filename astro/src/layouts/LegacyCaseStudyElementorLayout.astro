---
import SiteHeader from '../components/header/SiteHeader.astro';
import FooterEn from '../components/footer/FooterEn.astro';

type Props = {
  title: string;
  lang?: string;
  headExtraHtml?: string;
  bodyClass?: string;
  bodyItemType?: string;
  bodyItemscope?: boolean;
  headerHtml: string;
  contentHtml: string;
  footerHtml: string;
  afterFooterHtml?: string;
};

const {
  title,
  lang = 'es-ES',
  headExtraHtml = '',
  bodyClass = '',
  bodyItemType = '',
  bodyItemscope = false,
  headerHtml,
  contentHtml,
  footerHtml,
  afterFooterHtml = '',
} = Astro.props as Props;

const isEn = lang.toLowerCase().startsWith('en');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <Fragment set:html={headExtraHtml} />
  </head>
  <body class={bodyClass} itemtype={bodyItemType || undefined} itemscope={bodyItemscope}>
    {isEn ? <SiteHeader lang={lang} /> : <Fragment set:html={headerHtml} />}
    <Fragment set:html={contentHtml} />
    {isEn ? <FooterEn /> : <Fragment set:html={footerHtml} />}
    <Fragment set:html={afterFooterHtml} />
  </body>
</html>
