---
import HeaderEn from '../components/header/HeaderEn.astro';
import FooterEn from '../components/footer/FooterEn.astro';
import LegacyAssetBundle from '../components/head/LegacyAssetBundle.astro';
import type { LegacyBundleName } from '../lib/legacy-asset-bundles';
import { loadShellCss, loadShellCssMq, loadGlobalInlineCss } from '../lib/legacy-page';

const shellCss = loadShellCss('en');
const shellCssMq = loadShellCssMq('en');
const globalInlineCss = loadGlobalInlineCss('en');

type Props = {
  title: string;
  bodyClass: string;
  lang?: string;
  headExtraHtml?: string;
  afterBodyHtml?: string;
  bodyItemType?: string;
  cssBundles?: LegacyBundleName[];
  jsBundles?: LegacyBundleName[];
};

const {
  title,
  bodyClass,
  lang = 'en-US',
  headExtraHtml = '',
  afterBodyHtml = '',
  bodyItemType = 'https://schema.org/WebPage',
  cssBundles = [],
  jsBundles = [],
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {cssBundles.length > 0 && <LegacyAssetBundle bundleNames={cssBundles} />}
    {globalInlineCss && !headExtraHtml.includes('astra-theme-css-inline') && <style set:html={globalInlineCss} />}
    <style>
      .elementor-location-header {
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        position: relative;
        z-index: 1000;
      }

      .elementor-location-header .elementor-element-6f0aaa9,
      .elementor-location-header .elementor-element-9e15b9a,
      .elementor-location-header .elementor-element-947f5f9 {
        z-index: 1001;
      }

      #content,
      .site-content,
      .content-area,
      .site-main {
        position: relative;
        z-index: 1;
      }
    </style>
    <Fragment set:html={headExtraHtml} />
    {!headExtraHtml.includes('.elementor-10265') && shellCss && <style set:html={shellCss} />}
    {shellCssMq && <style set:html={shellCssMq} />}
  </head>
  <body itemtype={bodyItemType} itemscope="itemscope" class={bodyClass}>
    <a class="skip-link screen-reader-text" href="#content" title="Skip to content">Skip to content</a>
    <div class="hfeed site" id="page">
      <HeaderEn />
      <slot />
      <FooterEn />
    </div>
    {jsBundles.length > 0 && <LegacyAssetBundle bundleNames={jsBundles} />}
    <Fragment set:html={afterBodyHtml} />
  </body>
</html>
