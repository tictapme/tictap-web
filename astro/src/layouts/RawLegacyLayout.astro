---
import LegacyAssetBundle from '../components/head/LegacyAssetBundle.astro';
import type { LegacyBundleName } from '../lib/legacy-asset-bundles';
import SiteHeader from '../components/header/SiteHeader.astro';

type Props = {
  title: string;
  lang?: string;
  headExtraHtml?: string;
  bodyClass?: string;
  bodyItemType?: string;
  bodyItemscope?: boolean;
  bodyInnerHtml: string;
  cssBundles?: LegacyBundleName[];
  jsBundles?: LegacyBundleName[];
};

const {
  title,
  lang = 'es-ES',
  headExtraHtml = '',
  bodyClass = '',
  bodyItemType = '',
  bodyItemscope = false,
  bodyInnerHtml,
  cssBundles = [],
  jsBundles = [],
} = Astro.props as Props;

---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {cssBundles.length > 0 && <LegacyAssetBundle bundleNames={cssBundles} />}
    <Fragment set:html={headExtraHtml} />
    <style>.elementor-location-header { display: none !important; }</style>
  </head>
  <body class={bodyClass} itemtype={bodyItemType || undefined} itemscope={bodyItemscope}>
    <SiteHeader lang={lang} />
    <Fragment set:html={bodyInnerHtml} />
    {jsBundles.length > 0 && <LegacyAssetBundle bundleNames={jsBundles} />}
  </body>
</html>
