---
type Props = {
  title: string;
  lang?: string;
  headExtraHtml?: string;
  bodyClass?: string;
  targetUrl: string;
};

const {
  title,
  lang = 'es-ES',
  headExtraHtml = '',
  bodyClass = '',
  targetUrl,
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta http-equiv="refresh" content={`0;url=${targetUrl}`} />
    <Fragment set:html={headExtraHtml} />
  </head>
  <body class={bodyClass}>
    <script is:inline define:vars={{ targetUrl }}>
      window.location = targetUrl;
    </script>
    <p>
      Estás siendo redirigido a <a href={targetUrl}>{targetUrl}</a>
    </p>
  </body>
</html>
