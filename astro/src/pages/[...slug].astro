---
import GenericPageLayout from '../layouts/GenericPageLayout.astro';
import SolutionPageLayout from '../layouts/SolutionPageLayout.astro';
import CaseStudyArchiveLayout from '../layouts/CaseStudyArchiveLayout.astro';
import CaseStudySingleLayout from '../layouts/CaseStudySingleLayout.astro';
import LegacyCaseStudyElementorLayout from '../layouts/LegacyCaseStudyElementorLayout.astro';
import RedirectPageLayout from '../layouts/RedirectPageLayout.astro';
import RawLegacyLayout from '../layouts/RawLegacyLayout.astro';
import {
  listManagedLegacyRoutes,
  loadSourcePage,
  loadSourceRedirectPage,
  loadSourceStructuredElementorShellPage,
  loadSourceStructuredPage,
} from '../lib/legacy-page';
import { isSolutionPage } from '../lib/solution-pages';
import { caseStudies } from '../data/case-studies';

// Build EN→ES and ES→EN slug maps from the case-studies data
const enToEs: Record<string, string> = {};
const esToEn: Record<string, string> = {};
for (const cs of caseStudies) {
  if (cs.slug && cs.slugEn) {
    enToEs[cs.slugEn] = cs.slug;
    esToEn[cs.slug] = cs.slugEn;
  }
}
// Additional non-case-study pages where slugs differ between languages
enToEs['/en/stock/electrical-distributors/'] = '/stock/partners-distribuidores/';
esToEn['/stock/partners-distribuidores/'] = '/en/stock/electrical-distributors/';

export async function getStaticPaths() {
  return listManagedLegacyRoutes()
    .filter(({ route }) => route !== '/')
    .map(({ relativePath, route }) => ({
      params: {
        slug: route.replace(/^\/+|\/+$/g, ''),
      },
      props: {
        relativePath,
      },
    }));
}

const { relativePath } = Astro.props;
const rawPage = loadSourcePage(relativePath);
const isCaseStudyArchive =
  /^casos-de-exito\/index\.html$/i.test(relativePath) || /^en\/sucess-stories\/index\.html$/i.test(relativePath);
const isCaseStudySingleRoute =
  /^casos-de-exito\/.+\/index\.html$/i.test(relativePath) || /^en\/sucess-stories\/.+\/index\.html$/i.test(relativePath);
const isStructuredCaseStudySingle =
  isCaseStudySingleRoute &&
  /\bsingle-post\b/.test(rawPage.bodyClass) &&
  /\bast-blog-single-style-1\b/.test(rawPage.bodyClass);
const isLegacyElementorCaseStudySingle =
  isCaseStudySingleRoute &&
  /data-elementor-type=["']header["'][^>]+data-elementor-id=["']9610["']/i.test(rawPage.bodyInnerHtml) &&
  /data-elementor-type=["']footer["'][^>]+data-elementor-id=["']10152["']/i.test(rawPage.bodyInnerHtml);
const isRedirectPage =
  /<meta[^>]+http-equiv=["']refresh["']/i.test(rawPage.headExtraHtml) ||
  /window\.location\s*=/.test(rawPage.bodyInnerHtml);
const isSolutionPageRoute = isSolutionPage(relativePath);
const isGenericPage =
  !isSolutionPageRoute &&
  /\bpage-template-default\b/.test(rawPage.bodyClass) &&
  /\bpage-id-\d+\b/.test(rawPage.bodyClass) &&
  !/^\/?(en\/)?blog\//i.test(relativePath) &&
  !/^\/?(en\/)?casos-de-exito\//i.test(relativePath) &&
  !/^\/?(en\/)?sucess-stories\//i.test(relativePath) &&
  !/^\/?(en\/)?author\//i.test(relativePath) &&
  !/^\/?(en\/)?tag\//i.test(relativePath);

const isStructuredCaseStudy = isCaseStudyArchive || isStructuredCaseStudySingle;
let page = rawPage;
let legacyElementorPage = null;
let redirectPage = null;

if (isGenericPage || isSolutionPageRoute) {
  page = loadSourceStructuredPage(relativePath);
} else if (isStructuredCaseStudy && !isCaseStudyArchive) {
  try {
    page = loadSourceStructuredPage(relativePath);
  } catch {
    // fall through to RawLegacyLayout
  }
}

if (isLegacyElementorCaseStudySingle) {
  legacyElementorPage = loadSourceStructuredElementorShellPage(relativePath);
}

if (isRedirectPage) {
  redirectPage = loadSourceRedirectPage(relativePath);
}

const canRenderStructuredCaseStudy = isCaseStudyArchive || (page !== rawPage && isStructuredCaseStudy);

// Inject/replace hreflang alternate for case study pages where the slug differs between languages
function withCaseStudyHreflang(headHtml: string, currentSlug: string): string {
  const esSlug = enToEs[currentSlug];
  if (!esSlug) return headHtml;
  // Always replace: strip any existing hreflang="es" and prepend the correct one
  const cleaned = headHtml.replace(/<link[^>]+hreflang="es"[^>]*>\s*/gi, '');
  return `<link rel="alternate" hreflang="es" href="${esSlug}">\n` + cleaned;
}

function withCaseStudyHreflangEs(headHtml: string, currentSlug: string): string {
  const enSlug = esToEn[currentSlug];
  if (!enSlug) return headHtml;
  // Always replace: strip any existing hreflang="en" and prepend the correct one
  const cleaned = headHtml.replace(/<link[^>]+hreflang="en"[^>]*>\s*/gi, '');
  return `<link rel="alternate" hreflang="en" href="${enSlug}">\n` + cleaned;
}

const pageRoute = '/' + relativePath.replace(/index\.html$/, '');
const _baseHeadHtml = (legacyElementorPage ?? page).headExtraHtml;
const resolvedHeadHtml = /^\/en\//.test(pageRoute)
  ? withCaseStudyHreflang(_baseHeadHtml, pageRoute)
  : withCaseStudyHreflangEs(_baseHeadHtml, pageRoute);
---

{
  canRenderStructuredCaseStudy && isCaseStudyArchive ? (
    <CaseStudyArchiveLayout
      title={rawPage.title}
      lang={rawPage.lang}
      bodyClass={rawPage.bodyClass}
      bodyItemType={rawPage.bodyItemType}
      headExtraHtml={rawPage.headExtraHtml}
      afterBodyHtml=""
      contentHtml=""
    />
  ) : canRenderStructuredCaseStudy && isStructuredCaseStudySingle ? (
    <CaseStudySingleLayout
      title={page.title}
      lang={page.lang}
      bodyClass={page.bodyClass}
      bodyItemType={page.bodyItemType}
      headExtraHtml={resolvedHeadHtml}
      afterBodyHtml={page.afterFooterHtml}
      contentHtml={page.contentHtml}
    />
  ) : legacyElementorPage ? (
    <LegacyCaseStudyElementorLayout
      title={legacyElementorPage.title}
      lang={legacyElementorPage.lang}
      headExtraHtml={resolvedHeadHtml}
      bodyClass={legacyElementorPage.bodyClass}
      bodyItemType={legacyElementorPage.bodyItemType}
      bodyItemscope={legacyElementorPage.bodyItemscope}
      headerHtml={legacyElementorPage.headerHtml}
      contentHtml={legacyElementorPage.contentHtml}
      footerHtml={legacyElementorPage.footerHtml}
      afterFooterHtml={legacyElementorPage.afterFooterHtml}
    />
  ) : redirectPage ? (
    <RedirectPageLayout
      title={redirectPage.title}
      lang={redirectPage.lang}
      headExtraHtml={redirectPage.headExtraHtml}
      bodyClass={redirectPage.bodyClass}
      targetUrl={redirectPage.targetUrl}
    />
  ) : isSolutionPageRoute ? (
    <SolutionPageLayout
      title={page.title}
      lang={page.lang}
      bodyClass={page.bodyClass}
      bodyItemType={page.bodyItemType}
      headExtraHtml={resolvedHeadHtml}
      afterBodyHtml={page.afterFooterHtml}
      contentHtml={page.contentHtml}
    />
  ) : isGenericPage ? (
    <GenericPageLayout
      title={page.title}
      lang={page.lang}
      bodyClass={page.bodyClass}
      bodyItemType={page.bodyItemType}
      headExtraHtml={page.headExtraHtml}
      afterBodyHtml={page.afterFooterHtml}
      contentHtml={page.contentHtml}
    />
  ) : (
    <RawLegacyLayout
      title={page.title}
      lang={page.lang}
      headExtraHtml={resolvedHeadHtml}
      bodyClass={page.bodyClass}
      bodyItemType={page.bodyItemType}
      bodyItemscope={page.bodyItemscope}
      bodyInnerHtml={page.bodyInnerHtml}
    />
  )
}
