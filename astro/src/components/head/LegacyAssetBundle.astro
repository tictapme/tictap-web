---
import type { LegacyAsset, LegacyBundleName } from '../../lib/legacy-asset-bundles';
import { getLegacyBundle } from '../../lib/legacy-asset-bundles';

type Props = {
  bundleNames: LegacyBundleName[];
  extraAssets?: LegacyAsset[];
};

const { bundleNames, extraAssets = [] } = Astro.props as Props;
const assets = [...getLegacyBundle(...bundleNames), ...extraAssets];
---

{
  assets.map((asset) =>
    asset.kind === 'css' ? (
      <link rel="stylesheet" href={asset.href} id={asset.id} />
    ) : (
      <script src={asset.href} id={asset.id}></script>
    ),
  )
}
