#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] Building static site export"
npm run static:prepare

if ! git diff --ignore-all-space --quiet -- src; then
  echo "[pre-push] Committing updated static export"
  git add src/
  git commit -m "Rebuild static export"
fi
