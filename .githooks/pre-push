#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] Validating static export is up to date..."
npm run static:prepare

if ! git diff --ignore-all-space --quiet -- src; then
  echo ""
  echo "[pre-push] ERROR: src/ has uncommitted changes after the build."
  echo "  Run: npm run publish"
  echo ""
  exit 1
fi

echo "[pre-push] Static export is up to date. Proceeding with push."
