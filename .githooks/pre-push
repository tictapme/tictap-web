#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] Validating static export is up to date..."
npm run static:prepare

if ! git diff --ignore-all-space --quiet -- src; then
  echo ""
  echo "[pre-push] src/ updated by build — committing and pushing..."
  git add src/
  git commit -m "build: sync static export"
  git push --no-verify
  echo "[pre-push] Build commit pushed. Proceeding with original push."
else
  echo "[pre-push] Static export is up to date. Proceeding with push."
fi
